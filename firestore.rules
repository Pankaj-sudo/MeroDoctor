rules_version = '2';

// ============================================================================
// MeroDoctor — Firestore Security Rules
//   users            — one doc per account; role lives here (source of truth)
//   consultations    — the patient intake + doctor-managed lifecycle
//   activity_logs    — immutable audit trail of doctor actions
// Trust model: patients own their records; doctors/admin/clinic_staff manage
// consultations. Roles are read from /users/{uid}.role — never client input.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    function role() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'anonymous';
    }
    function isStaff() { return role() in ['doctor', 'admin', 'clinic_staff']; }
    function isAdmin() { return role() == 'admin'; }

    // The practice's registered physician email(s). A self-signup may claim the
    // 'doctor' role ONLY when the Firebase-verified token email is on this list,
    // so the Doctor Dashboard can never be reached by spoofing a role client-side.
    // Add emails here to onboard more doctors.
    function doctorEmails() { return ['pankaj.ydv707@gmail.com']; }
    function isDoctorEmail() {
      return request.auth != null && request.auth.token.email != null
        && request.auth.token.email.lower() in doctorEmails();
    }

    // ------------------------------------------------------------------ users
    match /users/{uid} {
      allow read: if isOwner(uid) || isStaff();
      // Self-signup may create a patient; the 'doctor' role is allowed only for a
      // registered physician email (verified by the auth token, not client input).
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && (request.resource.data.role == 'patient'
            || (request.resource.data.role == 'doctor' && isDoctorEmail()));
      // Owners may refresh their profile but not change their own role — except a
      // registered physician email may (self-)promote to 'doctor'. Admins may anything.
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.uid == resource.data.uid
            && (request.resource.data.role == resource.data.role
                || (request.resource.data.role == 'doctor' && isDoctorEmail())));
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------- consultations
    match /consultations/{id} {
      allow read: if isOwner(resource.data.patientId) || isStaff();

      // a patient creates their own consultation, starting at payment_pending
      allow create: if isSignedIn()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.status == 'payment_pending';

      // staff drive the whole lifecycle; the patient may ONLY re-touch payment
      // (e.g. re-upload a screenshot) and can never move their own status/clinical.
      allow update: if isStaff()
        || (isOwner(resource.data.patientId)
            && request.resource.data.patientId == resource.data.patientId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payment', 'updatedAt']));

      allow delete: if isAdmin();
    }

    // -------------------------------------------------------- audit / activity
    match /activity_logs/{id} {
      allow read: if isStaff();
      allow create: if isStaff() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false; // append-only audit trail
    }

    // ----------------------------------- future collections (locked by default)
    match /notifications/{id} { allow read, write: if isStaff(); }
  }
}
